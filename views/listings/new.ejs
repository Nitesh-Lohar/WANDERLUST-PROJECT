<%layout("/layouts/boilerplate.ejs")%>
<div class="row">
  <div class="col-8 offset-2">
    <h3 class="pt-3">Create a New Listing</h3>
    <form method="post" action="/listings" enctype="multipart/form-data" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          name="listing[title]"
          placeholder="Property Name"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Title looks good</div>
        <div class="invalid-feedback">Enter a valid title</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          placeholder="Enter description"
          type="text"
          class="form-control"
          required
        ></textarea>
        <div class="valid-feedback">Looks good</div>
        <div class="invalid-feedback">Enter a short description</div>
      </div>

      <div class="mb-3">
        <label for="listing[image]" class="form-label">Image File</label>
        <input
          name="listing[image]"
          type="file"
          class="form-control"
          accept="image/*"
          required
        />
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            name="listing[price]"
            placeholder="1200"
            class="form-control"
            type="number"
            required
          />
          <div class="valid-feedback">Looks good</div>
          <div class="invalid-feedback">Enter Price</div>
        </div>

        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            placeholder="India"
            type="text"
            class="form-control"
            required
          />
          <div class="valid-feedback">Looks good</div>
          <div class="invalid-feedback">Enter Country Name</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          name="listing[location]"
          placeholder="Jaipur Rajasthan"
          type="text"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good</div>
        <div class="invalid-feedback">Enter Location of the Property</div>
      </div>

      <div class="d-flex justify-content-center mt-3">
        <button
          class="btn btn-dark"
          style="background-color: #fe424d; border: none"
        >
          Add
        </button>
      </div>
    </form>
  </div>
</div>
