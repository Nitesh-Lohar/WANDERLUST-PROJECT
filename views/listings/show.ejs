<%layout("/layouts/boilerplate.ejs")%>

<div class="row">
  <div class="col-8 offset-3">
    <h2 class="mt-3">Listing Details</h2>
  </div>

  <div class="card col-6 offset-3 mt-3">
    <img
      src="<%=listing.image.url%>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body">
      <p class="card-text mt-2">
        <b><%= listing.title %></b> <br />
        <br />
        <%= listing.description %> <br />
        &#8377; <%= listing.price.toLocaleString("en-IN") %> <br />
        <%= listing.location %>, <%= listing.country %> <br />
      </p>
    </div>
  </div>

  <div class="col-6 offset-3 mt-3">
    <div class="d-flex justify-content-center gap-5">
    <a class="btn btn-dark mx-5 px-4" style="background-color: #fe424d; border: none;" href="/listings/<%=listing._id%>/edit">Edit</a>
    <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
      <button class="btn btn-dark mx-5 px-4">Delete</button>
    </form>
    </div>
  </div>
</div>
