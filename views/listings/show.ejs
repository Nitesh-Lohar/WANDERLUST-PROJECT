<%layout("/layouts/boilerplate.ejs")%>

<div class="row">
  <div class="col-8 offset-3">
    <h2 class="mt-3"><%= listing.title %></h2>
  </div>

  <div class="card listing-card col-6 offset-3 mt-3">
    <img
      src="<%=listing.image.url%>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body">
      <p class="card-text">Owned by: <i><%= listing.owner.username %></i></p>
      <p class="card-text"><%= listing.description %> </p>
      <p class="card-text">&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
      <p class="card-text"><%= listing.location %>, <%= listing.country %> </p>
    </div>
  </div>

  <div class="col-6 offset-3 mt-3">
    <div class="d-flex justify-content-center gap-5">
      <a
        class="btn btn-dark mx-5 px-4"
        style="background-color: #fe424d; border: none"
        href="/listings/<%=listing._id%>/edit"
        >Edit</a
      >
      <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark mx-5 px-4">Delete</button>
      </form>
    </div>
  </div>

  <div class="col-6 offset-3 mt-3">
    <hr />
    <h4>Leave a Review</h4>
    <form
      action="/listings/a/<%=listing._id%>/reviews"
      method="post"
      novalidate
      class="needs-validation"
    >
      <div class="col-4">
        <label for="rating" class="form-label">Rating</label>
        <input
          type="range"
          min="1"
          max="5"
          class="form-range"
          id="rating"
          name="review[rating]"
        />
      </div>
      <div class="col-8">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          class="form-control"
          cols="30"
          rows="5"
          placeholder="Enter your review"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter your review.</div>
      </div>
      <button class="btn btn-outline-dark mt-2">Submit</button>
    </form>
  </div>

  <div class="col-6 offset-3 mt-5">
    <hr>
    <h4>All Reviews</h4>
    <p><%= listing.reviews.length %> reviews</p>
    <div class="row">
    <% for (review of listing.reviews) { %>
      <div class="card mt-2 col-5 ms-2 mb-2">
        <div class="card-body">
          <h5 class="card-title">Jhon Doe</h5>
          <p class="card-text"><%= review.comment %></p>
          <p class="card-text">Rating: <%= review.rating %></p>
          <form class="mb-2" method="post" action="/listings/a/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
            <button class="btn btn-dark">Delete</button>
          </form>
        </div>
      </div>
    <% } %>
    </div>

  </div>

</div>
